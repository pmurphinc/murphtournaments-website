# Server-only API key used by server/routers.ts for Google Sheets API requests.
# Keep this value out of client-side VITE_* variables and never commit a real key.
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key

# Optional Twitch metadata integration.
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Auth/session and database configuration.
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgres://user:password@host:5432/database
OAUTH_SERVER_URL=https://example.com
OWNER_OPEN_ID=owner-open-id
VITE_APP_ID=your-app-id

# Discord OAuth for Team Finder. Use identify scope only.
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-domain.example/api/auth/discord/callback

# Discord Tournament Control authorization. These values are server-only; never
# expose DISCORD_BOT_TOKEN as a VITE_* browser variable. The bot must already be
# in the Murph Tournaments Discord server. Copy the guild ID and role IDs from
# Discord Developer Mode. Discord OAuth variables above remain required.
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-murph-tournaments-guild-id
DISCORD_TOURNAMENT_ADMIN_ROLE_ID=your-tournament-admin-role-id
DISCORD_TOURNAMENT_STAFF_ROLE_ID=your-tournament-staff-role-id

# Manus/Forge platform services when running in that environment.
BUILT_IN_FORGE_API_URL=https://example.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Discord tournament webhook authentication.
TOURNAMENT_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
